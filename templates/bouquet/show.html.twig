{% extends 'base.html.twig' %}

{% block title %}{{ bouquet.name }} — Bouquet Builder{% endblock %}
{% block page_title %}Bouquet Builder{% endblock %}

{% block body %}
<div class="page-wrapper px-4 sm:px-6 lg:px-8">

  <div class="page-header">
    <div class="page-header-info">
      <nav class="text-sm text-gray-400 mb-1">
        <a href="{{ path('app_bouquet_index') }}" class="hover:text-blue-600">Bouquets</a>
        <span class="mx-2">/</span>
        <span class="text-gray-700 font-medium">{{ bouquet.name }}</span>
      </nav>
      <h1>
        <i class="fas fa-spa" style="color:#4265d6;font-size:22px;"></i>
        {{ bouquet.name }}
        {% if bouquet.status == 'Draft' %}
          <span class="badge badge-warning ml-2">Draft</span>
        {% elseif bouquet.status == 'Ready' %}
          <span class="badge badge-success ml-2">Ready</span>
        {% elseif bouquet.status == 'Sold' %}
          <span class="badge badge-primary ml-2">Sold</span>
        {% elseif bouquet.status == 'Cancelled' %}
          <span class="badge badge-danger ml-2">Cancelled</span>
        {% endif %}
      </h1>
      {% if bouquet.description %}<p class="subtitle">{{ bouquet.description }}</p>{% endif %}
    </div>

    {# Status actions #}
    {% if bouquet.status not in ['Sold', 'Cancelled'] %}
      <div class="page-header-actions flex gap-2 flex-wrap">
        {% if bouquet.status == 'Draft' and bouquet.items is not empty %}
          <form method="POST" action="{{ path('app_bouquet_mark_ready', {id: bouquet.id}) }}">
            <input type="hidden" name="_token" value="{{ csrf_token('bouquet_status_' ~ bouquet.id) }}">
            <button type="submit" class="btn btn-success"><i class="fas fa-check-circle"></i> Mark Ready</button>
          </form>
        {% endif %}
        {% if bouquet.status == 'Ready' %}
          <form method="POST" action="{{ path('app_bouquet_mark_sold', {id: bouquet.id}) }}">
            <input type="hidden" name="_token" value="{{ csrf_token('bouquet_status_' ~ bouquet.id) }}">
            <button type="submit" class="btn btn-primary"><i class="fas fa-shopping-bag"></i> Mark Sold</button>
          </form>
        {% endif %}
        <form method="POST" action="{{ path('app_bouquet_cancel', {id: bouquet.id}) }}"
              onsubmit="return confirm('Cancel this bouquet? All stock will be restored.');">
          <input type="hidden" name="_token" value="{{ csrf_token('bouquet_status_' ~ bouquet.id) }}">
          <button type="submit" class="btn btn-danger btn-outline"><i class="fas fa-times"></i> Cancel Bouquet</button>
        </form>
      </div>
    {% endif %}
  </div>

  {% for label, messages in app.flashes %}
    {% for msg in messages %}
      <div class="alert alert-{{ label }} mb-4">{{ msg }}</div>
    {% endfor %}
  {% endfor %}

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">

    {# ── Left: Current bouquet items ── #}
    <div class="table-card">
      <div class="table-card-header flex items-center justify-between">
        <h3><i class="fas fa-list mr-2"></i>Bouquet Contents</h3>
        <span class="text-lg font-bold text-blue-700" id="total-price">₱{{ bouquet.totalPrice|number_format(2) }}</span>
      </div>

      {% if bouquet.items is empty %}
        <div class="p-8 text-center text-gray-400">
          <i class="fas fa-leaf text-4xl mb-3 block"></i>
          <p>No flowers added yet. Pick flowers from the right panel.</p>
        </div>
      {% else %}
        <div class="overflow-x-auto">
          <table class="fg-table min-w-full" id="items-table">
            <thead>
              <tr><th>Flower</th><th>Unit Price</th><th>Qty</th><th>Subtotal</th>{% if bouquet.status not in ['Sold','Cancelled'] %}<th></th>{% endif %}</tr>
            </thead>
            <tbody id="items-tbody">
              {% for item in bouquet.items %}
                <tr id="item-row-{{ item.id }}">
                  <td class="font-medium">{{ item.flower.name }}</td>
                  <td>₱{{ item.unitPrice|number_format(2) }}</td>
                  <td>{{ item.quantity }}</td>
                  <td class="font-semibold">₱{{ item.subtotal|number_format(2) }}</td>
                  {% if bouquet.status not in ['Sold','Cancelled'] %}
                    <td>
                      <button type="button"
                              class="btn btn-sm btn-danger btn-outline btn-remove-item"
                              data-item-id="{{ item.id }}"
                              title="Remove & restore stock">
                        <i class="fas fa-trash-alt"></i>
                      </button>
                    </td>
                  {% endif %}
                </tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
      {% endif %}

      {% if bouquet.notes %}
        <div class="p-4 border-t text-sm text-gray-500">
          <i class="fas fa-sticky-note mr-1"></i> {{ bouquet.notes }}
        </div>
      {% endif %}
    </div>

    {# ── Right: Add flowers ── #}
    {% if bouquet.status not in ['Sold', 'Cancelled'] %}
    <div class="table-card">
      <div class="table-card-header"><h3><i class="fas fa-plus-circle mr-2"></i>Add Flower to Bouquet</h3></div>

      <div class="p-4">
        <div class="relative mb-4">
          <i class="fas fa-search absolute left-3 top-3 text-gray-400"></i>
          <input type="text" id="flower-search" placeholder="Search flowers..."
                 class="w-full pl-9 pr-4 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-blue-500 focus:border-transparent">
        </div>

        <div id="add-error" class="hidden mb-3 p-3 bg-red-50 border border-red-200 rounded-lg text-red-700 text-sm"></div>
        <div id="add-success" class="hidden mb-3 p-3 bg-green-50 border border-green-200 rounded-lg text-green-700 text-sm"></div>

        <div id="flowers-list" class="space-y-2 max-h-[480px] overflow-y-auto pr-1">
          {% for flower in flowers %}
            <div class="flower-card bg-white border border-gray-200 rounded-xl p-3 transition hover:border-blue-400"
                 data-name="{{ flower.name|lower }}"
                 data-category="{{ flower.category|lower }}">
              <div class="flex items-center justify-between gap-3">
                <div class="flex-1 min-w-0">
                  <div class="font-semibold text-sm truncate">{{ flower.name }}</div>
                  <div class="text-xs text-gray-400">{{ flower.category }} &bull; {{ flower.freshnessStatus }}</div>
                  <div class="text-xs font-medium text-blue-700 mt-0.5">
                    {% if flower.discountPrice > 0 %}
                      <span class="line-through text-gray-400 mr-1">₱{{ flower.price|number_format(2) }}</span>₱{{ flower.discountPrice|number_format(2) }}
                    {% else %}
                      ₱{{ flower.price|number_format(2) }}
                    {% endif %}
                    <span class="text-gray-400 ml-2">Stock: <strong>{{ flower.stockQuantity }}</strong></span>
                  </div>
                </div>
                <div class="flex items-center gap-2 flex-shrink-0">
                  <input type="number" min="1" max="{{ flower.stockQuantity }}" value="1"
                         class="qty-input w-16 border border-gray-300 rounded-lg px-2 py-1 text-sm text-center focus:ring-1 focus:ring-blue-500">
                  <button type="button"
                          class="btn btn-sm btn-primary btn-add-flower"
                          data-flower-id="{{ flower.id }}"
                          data-flower-name="{{ flower.name }}">
                    <i class="fas fa-plus"></i>
                  </button>
                </div>
              </div>
            </div>
          {% else %}
            <div class="text-center text-gray-400 py-8">No flowers currently in stock.</div>
          {% endfor %}
        </div>
      </div>
    </div>
    {% endif %}

  </div>
</div>
{% endblock %}

{% block javascripts %}
  {{ parent() }}
  <script>
    const BOUQUET_ID     = {{ bouquet.id }};
    const TOKEN_ADD      = '{{ csrf_token('bouquet_add_flower') }}';
    const TOKEN_REMOVE   = '{{ csrf_token('bouquet_remove_item') }}';

    // ── Search ──
    const searchInput = document.getElementById('flower-search');
    if (searchInput) {
      searchInput.addEventListener('input', () => {
        const q = searchInput.value.toLowerCase();
        document.querySelectorAll('.flower-card').forEach(card => {
          const match = card.dataset.name.includes(q) || card.dataset.category.includes(q);
          card.style.display = match ? '' : 'none';
        });
      });
    }

    function showMessage(type, text) {
      const box = document.getElementById(type === 'error' ? 'add-error' : 'add-success');
      if (!box) return;
      box.textContent = text;
      box.classList.remove('hidden');
      setTimeout(() => box.classList.add('hidden'), 4000);
    }

    // ── Add flower ──
    document.querySelectorAll('.btn-add-flower').forEach(btn => {
      btn.addEventListener('click', async () => {
        const card = btn.closest('.flower-card');
        const qty  = parseInt(card.querySelector('.qty-input').value, 10);
        if (!qty || qty < 1) { showMessage('error', 'Enter a valid quantity.'); return; }

        const fd = new FormData();
        fd.append('_token', TOKEN_ADD);
        fd.append('flowerId', btn.dataset.flowerId);
        fd.append('quantity', qty);

        btn.disabled = true;
        const resp = await fetch(`/bouquet/${BOUQUET_ID}/add-flower`, { method: 'POST', body: fd });
        const data = await resp.json();
        btn.disabled = false;

        if (data.success) {
          showMessage('success', `Added ${data.quantity}× ${data.flowerName} to bouquet.`);
          document.getElementById('total-price').textContent = '₱' + parseFloat(data.totalPrice).toFixed(2);

          // Update stock display
          const stockEl = card.querySelector('strong');
          if (stockEl) stockEl.textContent = data.stockRemaining;

          // Append row to items table
          const tbody = document.getElementById('items-tbody');
          if (tbody) {
            const tr = document.createElement('tr');
            tr.id = 'item-row-' + data.itemId;
            tr.innerHTML = `
              <td class="font-medium">${data.flowerName}</td>
              <td>₱${parseFloat(data.unitPrice).toFixed(2)}</td>
              <td>${data.quantity}</td>
              <td class="font-semibold">₱${parseFloat(data.subtotal).toFixed(2)}</td>
              <td>
                <button type="button" class="btn btn-sm btn-danger btn-outline btn-remove-item"
                        data-item-id="${data.itemId}" title="Remove & restore stock">
                  <i class="fas fa-trash-alt"></i>
                </button>
              </td>`;
            tbody.appendChild(tr);
            bindRemoveBtn(tr.querySelector('.btn-remove-item'));
          }
        } else {
          showMessage('error', data.error);
        }
      });
    });

    // ── Remove item ──
    function bindRemoveBtn(btn) {
      btn.addEventListener('click', async () => {
        if (!confirm(`Remove this item and restore stock?`)) return;
        const itemId = btn.dataset.itemId;
        const fd = new FormData();
        fd.append('_token', TOKEN_REMOVE);

        btn.disabled = true;
        const resp = await fetch(`/bouquet/${BOUQUET_ID}/remove-item/${itemId}`, { method: 'POST', body: fd });
        const data = await resp.json();

        if (data.success) {
          document.getElementById('item-row-' + itemId)?.remove();
          document.getElementById('total-price').textContent = '₱' + parseFloat(data.totalPrice).toFixed(2);
        } else {
          btn.disabled = false;
          alert(data.error);
        }
      });
    }

    document.querySelectorAll('.btn-remove-item').forEach(bindRemoveBtn);
  </script>
{% endblock %}
