{% extends 'layouts/auth_base.html.twig' %}

{% block title %}Registration Pending - Floryn Garden{% endblock %}

{% block body %}
<div class="bg-white rounded-2xl shadow-2xl p-8 text-center">
    <!-- Logo -->
    <div class="flex justify-center mb-6">
        <img src="{{ asset('images/WEBDEV.png') }}" alt="Floryn Garden" style="max-height:110px;width:auto;object-fit:contain;">
    </div>

    <!-- Icon -->
    <div class="flex justify-center mb-5">
        <div class="h-20 w-20 rounded-full flex items-center justify-center" style="background:#fef9c3;">
            <i class="fas fa-hourglass-half text-4xl" style="color:#b45309;"></i>
        </div>
    </div>

    <!-- Heading -->
    <h1 class="text-2xl font-bold text-gray-900 mb-2">Account Pending Approval</h1>
    <p class="text-gray-500 text-sm mb-6">
        Thank you for registering! Your account has been created and is now waiting for an administrator to review and approve it.
        You will be able to log in once your account is activated.
    </p>

    <!-- Info box -->
    <div class="rounded-xl p-4 mb-6 text-left" style="background:#fef9c3;border:1px solid #fde68a;">
        <div class="flex items-start gap-3">
            <i class="fas fa-info-circle mt-0.5" style="color:#b45309;"></i>
            <div>
                <p class="text-sm font-semibold" style="color:#92400e;">What happens next?</p>
                <ul class="text-sm mt-1 space-y-1" style="color:#92400e;">
                    <li>• An admin will review your registration request</li>
                    <li>• Once approved, you can log in normally</li>
                    <li>• If rejected, your account will be removed</li>
                </ul>
            </div>
        </div>
    </div>

    <a href="{{ path('app_login') }}"
       class="w-full inline-flex items-center justify-center bg-[#293855] text-white font-semibold py-3 px-4 rounded-lg hover:bg-[#1e2d47] transition shadow-lg text-sm">
        <i class="fas fa-arrow-left mr-2"></i>Back to Login
    </a>
</div>
{% endblock %}
