{# templates/emails/google_login.html.twig #}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sign-in Notification — Floryn Garden</title>
    <style>
        body  { font-family: Arial, sans-serif; background: #f4f6f8;
                color: #333; margin: 0; padding: 0; }
        .wrap { max-width: 560px; margin: 40px auto; background: #ffffff;
                border-radius: 10px; overflow: hidden;
                box-shadow: 0 4px 12px rgba(0,0,0,.10); }
        .hdr  { background: linear-gradient(135deg, #5E548E 0%, #4C4375 100%);
                color: #fff; padding: 32px; text-align: center; }
        .hdr h1 { margin: 0; font-size: 24px; letter-spacing: .5px; }
        .hdr p  { margin: 8px 0 0; font-size: 14px; opacity: .85; }
        .google-badge { display: inline-flex; align-items: center; gap: 8px;
                background: #ffffff; color: #444; border-radius: 24px;
                padding: 8px 18px; margin-top: 16px; font-size: 14px;
                font-weight: bold; }
        .google-badge img { width: 18px; height: 18px; }
        .bdy  { padding: 36px 32px; }
        .bdy p { line-height: 1.7; font-size: 15px; margin: 0 0 16px; }
        .info-box { background: #f8f5ff; border-left: 4px solid #5E548E;
                    border-radius: 0 8px 8px 0; padding: 16px 20px;
                    margin: 20px 0; }
        .info-box p { margin: 0; font-size: 14px; color: #5E548E; font-weight: bold; }
        .info-box span { font-weight: normal; color: #555; }
        .divider { border: none; border-top: 1px solid #eee; margin: 24px 0; }
        .notice { font-size: 13px; color: #999; font-style: italic; }
        .ftr  { background: #f4f6f8; padding: 18px 32px;
                text-align: center; color: #94A3B8; font-size: 12px; }
        .ftr strong { color: #5E548E; }
    </style>
</head>
<body>
  <div class="wrap">

    <!-- Header -->
    <div class="hdr">
        <h1>🌸 Floryn Garden</h1>
        <p>Sign-in Notification</p>
        <div class="google-badge">
            <svg width="18" height="18" viewBox="0 0 48 48">
                <path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/>
                <path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/>
                <path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/>
                <path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.18 1.48-4.97 2.31-8.16 2.31-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/>
            </svg>
            Signed in via Google
        </div>
    </div>

    <!-- Body -->
    <div class="bdy">
        <p>Hi <strong>{{ user.username }}</strong>,</p>
        <p>
            We noticed a new sign-in to your <strong>Floryn Garden</strong> account
            using your Google account. Here are the details:
        </p>

        <div class="info-box">
            <p>🕐 Time: <span>{{ loginTime|date('F j, Y — g:i A') }}</span></p>
            <p style="margin-top:10px;">📧 Account: <span>{{ user.email }}</span></p>
            <p style="margin-top:10px;">🔑 Method: <span>Google OAuth</span></p>
        </div>

        <p>
            If this was you, no action is needed — you're all set! 🎉
        </p>

        <hr class="divider">

        <p class="notice">
            If you did <strong>not</strong> sign in, please contact the admin immediately
            or change your Google account password to secure your account.
        </p>

        <p>Thanks,<br><strong>Floryn Garden Team</strong></p>
    </div>

    <!-- Footer -->
    <div class="ftr">
        <p style="margin:0;">© 2025 <strong>Floryn Garden System</strong>. All rights reserved.</p>
        <p style="margin:6px 0 0;">This is an automated security notification, please do not reply.</p>
    </div>

  </div>
</body>
</html>
