{# templates/emails/verification.html.twig #}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Verify Your Email — Floryn Garden</title>
    <style>
        body  { font-family: Arial, sans-serif; background: #f4f6f8;
                color: #333; margin: 0; padding: 0; }
        .wrap { max-width: 560px; margin: 40px auto; background: #ffffff;
                border-radius: 10px; overflow: hidden;
                box-shadow: 0 4px 12px rgba(0,0,0,.10); }
        .hdr  { background: linear-gradient(135deg, #5E548E 0%, #4C4375 100%);
                color: #fff; padding: 32px; text-align: center; }
        .hdr h1 { margin: 0; font-size: 24px; letter-spacing: .5px; }
        .hdr p  { margin: 8px 0 0; font-size: 14px; opacity: .85; }
        .bdy  { padding: 36px 32px; }
        .bdy p { line-height: 1.7; font-size: 15px; margin: 0 0 16px; }
        .btn-wrap { text-align: center; margin: 28px 0; }
        .btn  { display: inline-block; background: #5E548E;
                color: #fff !important; padding: 14px 36px;
                text-decoration: none; border-radius: 8px;
                font-weight: bold; font-size: 16px; letter-spacing: .3px; }
        .btn:hover { background: #4C4375; }
        .divider { border: none; border-top: 1px solid #eee; margin: 24px 0; }
        .link-label { font-size: 13px; color: #666; margin: 0 0 6px; }
        .link { word-break: break-all; color: #5E548E;
                font-size: 13px; line-height: 1.5; }
        .notice { font-size: 13px; color: #999; font-style: italic; }
        .ftr  { background: #f4f6f8; padding: 18px 32px;
                text-align: center; color: #94A3B8; font-size: 12px; }
        .ftr strong { color: #5E548E; }
    </style>
</head>
<body>
  <div class="wrap">

    <!-- Header -->
    <div class="hdr">
        <h1>🌸 Floryn Garden</h1>
        <p>Email Verification</p>
    </div>

    <!-- Body -->
    <div class="bdy">
        <p>Hi <strong>{{ user.username }}</strong>,</p>
        <p>
            Thank you for creating an account at <strong>Floryn Garden</strong>!
            To complete your registration, please verify your email address
            by clicking the button below:
        </p>

        <div class="btn-wrap">
            <a href="{{ verificationUrl }}" class="btn">
                ✉️&nbsp; Verify Email Address
            </a>
        </div>

        <p>
            After verifying your email, your account will still need to be
            <strong>approved by an admin</strong> before you can log in.
            We'll let you know once that's done.
        </p>

        <hr class="divider">

        <p class="link-label">Or copy and paste this link into your browser:</p>
        <p class="link">{{ verificationUrl }}</p>

        <hr class="divider">

        <p class="notice">
            This link is <strong>single-use</strong> and will become invalid once clicked.
            If you did not create an account, please ignore this email.
        </p>

        <p>Thanks,<br><strong>Floryn Garden Team</strong></p>
    </div>

    <!-- Footer -->
    <div class="ftr">
        <p style="margin:0;">© 2025 <strong>Floryn Garden System</strong>. All rights reserved.</p>
        <p style="margin:6px 0 0;">This is an automated email, please do not reply.</p>
    </div>

  </div>
</body>
</html>
