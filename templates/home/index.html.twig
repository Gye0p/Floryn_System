        {% set palette = palettes[loop.index0 % 8] %}
        {% set badgeLabels = ['Bestseller','New','Popular','Sale','Fresh'] %}
        {% set badgeClasses = ['pbadge-rose','pbadge-green','pbadge-rose','pbadge-gold','pbadge-green'] %}
        {% set bi = loop.index0 % 5 %}
        <div class="pc">
          <div class="pimg {{ palette }}">
            <div class="pimg-inner">
              {# Inline flower SVG icon — decorative placeholder #}
              <svg class="card-svg" viewBox="0 0 100 140" fill="none" xmlns="http://www.w3.org/2000/svg">
                <line x1="50" y1="140" x2="50" y2="40" stroke="#243B2E" stroke-width="1.5" opacity=".35"/>
                <ellipse cx="50" cy="55" rx="18" ry="26" fill="#243B2E" opacity=".32"/>
                <ellipse cx="35" cy="65" rx="16" ry="9" fill="#7A9E87" opacity=".48" transform="rotate(-22 35 65)"/>
                <ellipse cx="65" cy="72" rx="16" ry="9" fill="#7A9E87" opacity=".48" transform="rotate(22 65 72)"/>
                <ellipse cx="50" cy="38" rx="10" ry="15" fill="#3A5C47" opacity=".5"/>
                <circle cx="50" cy="28" r="8" fill="#7A9E87" opacity=".6"/>
              </svg>
            </div>
            {% if loop.index <= 5 %}
              <span class="pbadge {{ badgeClasses[bi] }}">{{ badgeLabels[bi] }}</span>
            {% endif %}
            <div class="pov">
              <a href="{{ path('app_login') }}" class="pov-btn">View</a>
              <a href="{{ path('app_login') }}" class="pov-btn filled">Order</a>
            </div>
          </div>
          <div class="pinfo">
            <div class="pocc">{{ bouquet.status }}</div>
            <div class="pname">{{ bouquet.name }}</div>
            <div class="pdesc">{{ bouquet.description|default('A beautifully handcrafted floral arrangement made with the freshest blooms.')|slice(0,90) }}{% if bouquet.description|length > 90 %}…{% endif %}</div>
            <div class="pfoot">
              <div class="pprice">&#8369; {{ bouquet.totalPrice|number_format(2) }}</div>
