{# ═══════ WHY US ═══════ #}
<section class="sec why-bg" id="why">
  <div class="why-layout">
    <div>
      <div class="eyebrow">Why Floryn?</div>
      <h2 class="sec-h2">More than<br><em>just flowers</em></h2>
      <p class="why-body">We believe every bouquet carries a message. That's why we source only the freshest blooms, arrange them by hand with care, and have them ready for pickup on time — every single time. Because your moments deserve nothing less.</p>
      <a href="{{ path('app_login') }}" class="btn-forest">
        Start Shopping
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>
    <div class="why-cards">
      <div class="wc">
        <div class="wc-icon ic-rose">
          <svg viewBox="0 0 24 24" stroke-width="1.5"><path d="M12 22s-8-4.5-8-11.8A8 8 0 0112 2a8 8 0 018 8.2c0 7.3-8 11.8-8 11.8z"/><path d="M12 13a3 3 0 100-6 3 3 0 000 6z"/></svg>
