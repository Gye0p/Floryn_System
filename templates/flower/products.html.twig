{% extends 'base.html.twig' %}

{% block title %}Flower Products{% endblock %}
{% block page_title %}Flower Products{% endblock %}

{% block body %}
<div class="page-wrapper px-4 sm:px-6 lg:px-8">
  <div class="page-header">
    <div class="page-header-info">
      <h1><i class="fas fa-seedling" style="color:#4265d6;font-size:22px;"></i> Product Catalog</h1>
      <p class="subtitle">Browse available flowers. Image files are served from <strong>public/uploads/flowers/</strong>.</p>
    </div>
  </div>

  {% if flowers is empty %}
    <div class="section-card">
      <div class="empty-state">
        <div class="empty-state-icon"><i class="fas fa-box-open"></i></div>
        <h3>No products available</h3>
        <p>Add flowers or restock inventory to display products here.</p>
      </div>
    </div>
  {% else %}
    <div class="grid gap-5" style="grid-template-columns:repeat(auto-fill,minmax(220px,1fr));">
      {% for flower in flowers %}
        <article class="section-card" style="padding:0;overflow:hidden;">
          <div style="position:relative;height:170px;background:#f4f6fb;">
            {% if flower.imageFilename %}
              <img
                src="{{ asset('uploads/flowers/' ~ flower.imageFilename) }}"
                alt="{{ flower.name }}"
                loading="lazy"
                style="width:100%;height:100%;object-fit:cover;"
                onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
              >
              <div style="display:none;width:100%;height:100%;align-items:center;justify-content:center;color:#94a3b8;">
                <i class="fas fa-image" style="font-size:28px;"></i>
              </div>
            {% else %}
              <div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;color:#94a3b8;">
                <i class="fas fa-leaf" style="font-size:32px;"></i>
              </div>
            {% endif %}
          </div>
          <div style="padding:14px 14px 16px;">
            <h3 style="font-size:15px;font-weight:700;color:var(--navy);line-height:1.3;">{{ flower.name }}</h3>
            <p style="font-size:12px;color:var(--muted);margin-top:3px;">{{ flower.category }}</p>
            <div style="display:flex;align-items:center;justify-content:space-between;margin-top:10px;">
              <span style="font-weight:700;color:#0f172a;font-size:14px;">PHP {{ flower.price|number_format(2) }}</span>
              <span class="pill {% if flower.stockQuantity < 5 %}red{% else %}green{% endif %}">
                {{ flower.stockQuantity }} in stock
              </span>
            </div>
            <p style="font-size:11px;color:#64748b;margin-top:10px;">
              File: {{ flower.imageFilename ?: 'no image filename' }}
            </p>
          </div>
        </article>
      {% endfor %}
    </div>
  {% endif %}
</div>
{% endblock %}
